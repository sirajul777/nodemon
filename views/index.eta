<% layout("./layout") %>

<!-- Include the modular sidebar -->
<%~ include("./partials/sidebar") %>

<div id="main">
  <!-- Topbar code goes here -->
<%~ include("./partials/topbar") %>

    <div id="content">
        <!-- ══ DASHBOARD ══ -->
        <div class="page active" id="page-dashboard">
            <!-- Stat bar -->
            <!-- Main content grid -->
            <div class="gcol">
            <!-- Left column -->
            <div>
                <div class="stat-bar">
                <div class="sbc c-green">
                    <div class="sbc-icon"><i class="fa fa-money"></i></div>
                    <div>
                    <div class="sbc-val" id="db-today-inc">—</div>
                    <div class="sbc-lbl">Revenue Hari Ini</div>
                    </div>
                </div>
                <div class="sbc c-cyan">
                    <div class="sbc-icon"><i class="fa fa-calendar"></i></div>
                    <div>
                    <div class="sbc-val" id="db-month-inc">—</div>
                    <div class="sbc-lbl">Revenue Bulan Ini</div>
                    </div>
                </div>
                <div class="sbc c-blue">
                    <div class="sbc-icon"><i class="fa fa-ticket"></i></div>
                    <div>
                    <div class="sbc-val" id="db-today-vcr">—</div>
                    <div class="sbc-lbl">Voucher Hari Ini</div>
                    </div>
                </div>
                <div class="sbc c-purple">
                    <div class="sbc-icon"><i class="fa fa-ticket"></i></div>
                    <div>
                    <div class="sbc-val" id="db-month-vcr">—</div>
                    <div class="sbc-lbl">Voucher Bulan Ini</div>
                    </div>
                </div>
                <!-- <div class="sbc c-yellow">
                <div class="sbc-icon"><i class="fa fa-wifi"></i></div>
                <div><div class="sbc-val" id="db-hs-online">—</div><div class="sbc-lbl">Hotspot Online</div></div>
            </div>
            <div class="sbc c-orange" style="--c:var(--orange)">
                <div class="sbc-icon" style="background:#db6d2818;color:var(--orange)"><i class="fa fa-plug"></i></div>
                <div><div class="sbc-val" id="db-ppp-online">—</div><div class="sbc-lbl">PPPoE Online</div></div>
            </div> -->
                </div>

                <!-- HS + PPPoE panels -->
                <div class="g2" style="margin-bottom: 14px">
                <div class="net-panel">
                    <div class="net-label">
                    <i class="fa fa-wifi"></i> HOTSPOT
                    </div>
                    <div class="net-stats">
                    <div class="ns">
                        <div class="ns-ico gr"><i class="fa fa-users"></i></div>
                        <div>
                        <div class="ns-val" id="db-hs-total">—</div>
                        <div class="ns-lbl">Total User</div>
                        </div>
                    </div>
                    <div class="ns">
                        <div class="ns-ico bl"><i class="fa fa-laptop"></i></div>
                        <div>
                        <div class="ns-val" id="db-hs-active2">—</div>
                        <div class="ns-lbl">Online</div>
                        </div>
                    </div>
                    </div>
                </div>
                <div class="net-panel">
                    <div class="net-label"><i class="fa fa-plug"></i> PPPOE</div>
                    <div class="net-stats">
                    <div class="ns">
                        <div class="ns-ico pu"><i class="fa fa-users"></i></div>
                        <div>
                        <div class="ns-val" id="db-ppp-total">—</div>
                        <div class="ns-lbl">Total User</div>
                        </div>
                    </div>
                    <div class="ns">
                        <div class="ns-ico or"><i class="fa fa-plug"></i></div>
                        <div>
                        <div class="ns-val" id="db-ppp-active2">—</div>
                        <div class="ns-lbl">Online</div>
                        </div>
                    </div>
                    </div>
                </div>
                </div>

                <!-- Log Aktivitas -->
                <div class="card">
                <div class="card-hd">
                    <i class="fa fa-list-ul"></i> Log Aktivitas Sistem
                    <button class="btn b-s b-sm ml" onclick="loadDashboard()">
                    <i class="fa fa-refresh"></i>
                    </button>
                </div>
                <div class="log-filters">
                    <button
                    class="lf-btn active"
                    onclick="filterLog('all', this)"
                    >
                    Semua <span class="cnt" id="lc-all">0</span>
                    </button>
                    <button class="lf-btn" onclick="filterLog('hs', this)">
                    Hotspot <span class="cnt" id="lc-hs">0</span>
                    </button>
                    <button class="lf-btn" onclick="filterLog('ppp', this)">
                    PPPoE <span class="cnt" id="lc-ppp">0</span>
                    </button>
                </div>
                <div class="log-list" id="log-list">
                    <div
                    style="
                        text-align: center;
                        color: var(--muted);
                        padding: 20px;
                    "
                    >
                    Loading...
                    </div>
                </div>
                </div>
            </div>

            <!-- Right column: Status NAS -->
            <div>
                <div class="card">
                <div class="card-hd">
                    <i class="fa fa-server"></i> Status Router
                    <button class="btn b-s b-sm ml" onclick="loadDashboard()">
                    <i class="fa fa-refresh"></i>
                    </button>
                </div>
                <div id="nas-list">
                    <div
                    style="
                        text-align: center;
                        color: var(--muted);
                        padding: 20px;
                    "
                    >
                    Pilih router dulu
                    </div>
                </div>
                </div>
                <div class="traffic-card" id="traffic-card">
                <!-- Header -->
                <div class="traffic-hd">
                    <div class="traffic-hd-left">
                    <div
                        style="
                        width: 32px;
                        height: 32px;
                        border-radius: 9px;
                        background: rgba(56, 189, 248, 0.12);
                        color: #38bdf8;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 0.9rem;
                        "
                    >
                        <i class="fa fa-line-chart"></i>
                    </div>
                    <div>
                        <div class="traffic-hd-title">Trafik Interface</div>
                        <div class="traffic-live-dot">Live · 5s</div>
                    </div>
                    </div>
                    <div
                    style="
                        display: flex;
                        align-items: center;
                        gap: 8px;
                        flex-wrap: wrap;
                    "
                    >
                    <select
                        id="traffic-iface-sel"
                        onchange="onTrafficIfaceChange()"
                    >
                        <option value="">— Pilih Interface —</option>
                    </select>
                    <!-- Countdown ring -->
                    <div class="traffic-countdown" title="Refresh dalam...">
                        <svg width="22" height="22" viewBox="0 0 22 22">
                        <circle
                            cx="11"
                            cy="11"
                            r="9"
                            fill="none"
                            stroke="var(--border)"
                            stroke-width="2.5"
                        />
                        <circle
                            id="traffic-ring"
                            cx="11"
                            cy="11"
                            r="9"
                            fill="none"
                            stroke="#38bdf8"
                            stroke-width="2.5"
                            stroke-dasharray="56.5"
                            stroke-dashoffset="0"
                            stroke-linecap="round"
                        />
                        </svg>
                        <span id="traffic-cd">5s</span>
                    </div>
                    <!-- Pause -->
                    <button
                        class="traffic-pause-btn"
                        id="traffic-pause-btn"
                        onclick="toggleTrafficPause()"
                    >
                        <i class="fa fa-pause" id="traffic-pause-icon"></i>
                        <span id="traffic-pause-lbl">Pause</span>
                    </button>
                    <!-- Refresh -->
                    <button
                        class="btn b-s b-sm"
                        onclick="fetchTrafficNow()"
                        title="Refresh sekarang"
                    >
                        <i class="fa fa-refresh"></i>
                    </button>
                    </div>
                </div>

                <!-- Body: empty state or live data -->
                <div id="traffic-body">
                    <div class="traffic-empty">
                    <i class="fa fa-plug"></i>
                    Pilih router dan interface untuk melihat trafik realtime
                    </div>
                </div>
                </div>
                <!-- /traffic-card -->

                <!-- </div>/STEP2 wrapper -->
            </div>
            </div>
        </div>

        <!-- ══ HOTSPOT ACTIVE ══ -->
        <div class="page" id="page-hs-active">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-laptop"></i> Hotspot Active
                <span
                id="ha-ct"
                style="
                    color: var(--muted);
                    font-weight: normal;
                    font-size: 0.78rem;
                    margin-left: 5px;
                "
                ></span>
                <button class="btn b-s b-sm ml" onclick="loadHsActive()">
                <i class="fa fa-refresh"></i>
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>User</th>
                    <th>IP</th>
                    <th>MAC</th>
                    <th>Uptime</th>
                    <th>Session Left</th>
                    </tr>
                </thead>
                <tbody id="t-ha"></tbody>
                </table>
            </div>
            <div id="pg-t-ha"></div>
            </div>
        </div>

        <!-- ══ HOTSPOT USERS ══ -->
        <div class="page" id="page-hs-users">
            <div class="card">
            <div class="card-hd"><i class="fa fa-users"></i> Hotspot Users</div>
            <div class="fb">
                <div class="fg">
                <label>Search</label
                ><input
                    id="uq"
                    placeholder="username..."
                    oninput="filterTbl('t-hu', 'uq')"
                    style="max-width: 170px"
                />
                </div>
                <div class="fg">
                <label>Profile</label
                ><select id="uprof" onchange="loadHsUsers()">
                    <option value="all">All</option>
                </select>
                </div>
                <div
                id="hu-bulk"
                class="fg"
                style="display: none; align-items: flex-end"
                >
                <button class="btn b-d" onclick="bulkDelHs()">
                    <i class="fa fa-trash"></i> Hapus (<span id="hu-sel-count"
                    >0</span
                    >)
                </button>
                </div>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th style="width: 30px">
                        <input
                        type="checkbox"
                        id="hu-all"
                        onclick="toggleAllHs(this.checked)"
                        />
                    </th>
                    <th>Username</th>
                    <th>Profile</th>
                    <th>Comment</th>
                    <th>Limit</th>
                    <th style="width: 50px"></th>
                    </tr>
                </thead>
                <tbody id="t-hu"></tbody>
                </table>
            </div>
            <div id="pg-t-hu"></div>
            </div>
        </div>
        <!-- ══ HOTSPOT PROFILES ══ -->
        <div class="page" id="page-hs-profiles">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-id-card"></i> Hotspot User Profiles
                <button class="btn b-p b-sm ml" onclick="openHsProfileModal()">
                <i class="fa fa-plus"></i> Add Profile
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Name</th>
                    <th>Rate Limit</th>
                    <th>Shared</th>
                    <th>Expired Mode</th>
                    <th>Validity</th>
                    <th>Price</th>
                    <th>Sell Price</th>
                    <th></th>
                    </tr>
                </thead>
                <tbody id="t-hsp"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ PPPoE ACTIVE ══ -->
        <div class="page" id="page-ppp-active">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-plug"></i> PPPoE Active
                <span
                id="pa-ct"
                style="
                    color: var(--muted);
                    font-weight: normal;
                    font-size: 0.78rem;
                    margin-left: 5px;
                "
                ></span>
                <button class="btn b-s b-sm ml" onclick="loadPppActive()">
                <i class="fa fa-refresh"></i>
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Name</th>
                    <th>Service</th>
                    <th>Caller ID</th>
                    <th>Address</th>
                    <th>Uptime</th>
                    <th></th>
                    </tr>
                </thead>
                <tbody id="t-pa"></tbody>
                </table>
            </div>
            <div id="pg-t-pa"></div>
            </div>
        </div>

        <!-- ══ PPPoE USERS ══ -->
        <div class="page" id="page-ppp-users">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-users"></i> PPPoE Users
                <button class="btn b-p b-sm ml" onclick="openPppUserModal()">
                <i class="fa fa-plus"></i> Add User
                </button>
            </div>
            <div class="fb">
                <div class="fg">
                <label>Search</label
                ><input
                    id="pq"
                    placeholder="username..."
                    oninput="filterTbl('t-ps', 'pq')"
                    style="max-width: 170px"
                />
                </div>
                <div class="fg">
                <label>Profile</label
                ><select id="ppp-prof-filter" onchange="loadPppUsers()">
                    <option value="all">All</option>
                </select>
                </div>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Username</th>
                    <th>Profile</th>
                    <th>Service</th>
                    <th>Local IP</th>
                    <th>Remote IP</th>
                    <th>Comment</th>
                    <th>Status</th>
                    <th></th>
                    </tr>
                </thead>
                <tbody id="t-ps"></tbody>
                </table>
            </div>
            <div id="pg-t-ps"></div>
            </div>
        </div>

        <!-- ══ PPPoE PROFILES ══ -->
        <div class="page" id="page-ppp-profiles">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-id-card-o"></i> PPPoE Profiles
                <button class="btn b-p b-sm ml" onclick="openPppProfileModal()">
                <i class="fa fa-plus"></i> Add Profile
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Name</th>
                    <th>Rate Limit</th>
                    <th>Address Pool</th>
                    <th>Session Timeout</th>
                    <th>Only One</th>
                    <th></th>
                    </tr>
                </thead>
                <tbody id="t-pp"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ RESELLER ══ -->
        <div class="page" id="page-reseller">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-handshake-o"></i> Reseller
                <button class="btn b-p b-sm ml" onclick="openResellerModal()">
                <i class="fa fa-plus"></i> Add Reseller
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Name</th>
                    <th>ID/Tag</th>
                    <th>Phone</th>
                    <th>Discount</th>
                    <th></th>
                    </tr>
                </thead>
                <tbody id="t-rs"></tbody>
                </table>
            </div>
            <div id="pg-t-rs"></div>
            </div>
        </div>

        <!-- ══ BATCH VOUCHER ══ -->
        <div class="page" id="page-batch">
            <div class="g2">
            <div class="card">
                <div class="card-hd">
                <i class="fa fa-ticket"></i> Generate Batch Voucher
                </div>
                <div class="fg">
                <label>Profile</label
                ><select id="bv-prof"></select>
                </div>
                <div class="fg2">
                <div class="fg">
                    <label>User Type</label
                    ><select id="bv-type">
                    <option value="up">User + Password</option>
                    <option value="vc">User = Password</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Char Type</label
                    ><select id="bv-char">
                    <option value="lowerdigit">Small Letters + Digits</option>
                    <option value="upperdigit">Capital Letters + Digits</option>
                    <option value="mixeddigit">Mixed Letters + Digits</option>
                    <option value="digit">Digits only</option>
                    <option value="alphabet">Letters only</option>
                    <option value="lower">Small Letters only</option>
                    <option value="upper">Capital Letters only</option>
                    </select>
                </div>
                </div>
                <div class="fg2">
                <div class="fg">
                    <label>Quantity</label
                    ><input
                    id="bv-qty"
                    type="number"
                    value="10"
                    min="1"
                    max="500"
                    />
                </div>
                <div class="fg">
                    <label>Length</label
                    ><input
                    id="bv-ulen"
                    type="number"
                    value="5"
                    min="3"
                    max="12"
                    />
                </div>
                </div>
                <div class="fg2">
                <div class="fg">
                    <label>Prefix</label
                    ><input id="bv-pfx" placeholder="opsional" />
                </div>
                <div class="fg">
                    <label>Time Limit</label
                    ><input id="bv-val" placeholder="dari profile" />
                </div>
                </div>
                <div class="fg">
                <label>Reseller</label
                ><select id="bv-rs">
                    <option value="">— Tanpa Reseller —</option>
                </select>
                </div>
                <div style="display: flex; gap: 8px">
                <button
                    class="btn b-p"
                    onclick="generateVouchers(false)"
                    id="btn-gen"
                >
                    <i class="fa fa-bolt"></i> Generate & Simpan
                </button>
                <button class="btn b-s" onclick="generateVouchers(true)">
                    <i class="fa fa-download"></i> CSV
                </button>
                </div>
                <div class="err" id="bv-err"></div>
            </div>
            <div class="card">
                <div class="card-hd">
                <i class="fa fa-list"></i> Hasil
                <span
                    id="gen-ct"
                    style="
                    color: var(--muted);
                    font-weight: normal;
                    font-size: 0.78rem;
                    "
                ></span>
                <div class="ml" style="display: flex; gap: 5px">
                    <button
                    class="btn b-s b-sm"
                    id="btn-cp"
                    onclick="copyVouchers()"
                    style="display: none"
                    >
                    <i class="fa fa-copy"></i> Copy
                    </button>
                    <button
                    class="btn b-p b-sm"
                    id="btn-print"
                    onclick="openPrintModal()"
                    style="display: none"
                    >
                    <i class="fa fa-print"></i> Print
                    </button>
                </div>
                </div>
                <div id="vr" style="color: var(--muted); font-size: 0.82rem">
                Belum ada voucher.
                </div>
            </div>
            </div>
        </div>

        <!-- ══ BATCH LIST ══ -->
        <div class="page" id="page-batch-list">
            <!-- Batch cards grid -->
            <div id="batch-cards-area">
            <div
                style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 14px;
                flex-wrap: wrap;
                gap: 8px;
                "
            >
                <div
                style="
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    flex-wrap: wrap;
                "
                >
                <span
                    id="batch-count-label"
                    style="color: var(--muted); font-size: 0.85rem"
                ></span>
                <select
                    id="batch-filter-profile"
                    onchange="loadBatchList()"
                    style="max-width: 160px"
                >
                    <option value="">Semua Package</option>
                </select>
                </div>
                <div style="display: flex; gap: 7px">
                <button class="btn b-s" onclick="loadBatchList()">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
                <button
                    class="btn b-s"
                    onclick="syncBatchToReport()"
                    style="color: var(--green); border-color: var(--green)"
                >
                    <i class="fa fa-upload"></i> Sync ke Selling Report
                </button>
                <button
                    class="btn b-s"
                    onclick="syncUsedFromMikrotik()"
                    style="color: var(--cyan); border-color: var(--cyan)"
                >
                    <i class="fa fa-refresh"></i> Sync Status Terpakai
                </button>
                <div id="STEP2_HTML_INSERT_BEFORE_IMPORT_BUTTON">
                    <!-- Paste baris ini: -->
                    <div
                    class="ar-toggle-wrap"
                    id="ar-toggle"
                    onclick="toggleAutoRemoveSetting()"
                    title="Otomatis hapus batch yang sudah habis terjual"
                    >
                    <div class="ar-pill" id="ar-pill"></div>
                    <span id="ar-label">Auto Hapus Batch Habis</span>
                    </div>
                </div>
                <button
                    class="btn b-p"
                    id="btn-import"
                    onclick="importFromMikrotik()"
                >
                    <i class="fa fa-download"></i> Import dari MikroTik
                </button>
                </div>
            </div>
            <div
                id="batch-grid"
                style="
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 12px;
                "
            ></div>
            </div>

            <!-- Batch detail (shown when a batch is clicked) -->
            <div id="batch-detail-area" style="display: none">
            <div
                style="
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 14px;
                "
            >
                <button class="btn b-s" onclick="closeBatchDetail()">
                <i class="fa fa-arrow-left"></i> Kembali
                </button>
                <span style="font-size: 0.95rem; font-weight: 600"
                >Voucher: <span id="bd-title" style="color: var(--acc2)"></span
                ></span>
                <div style="margin-left: auto; display: flex; gap: 7px">
                <button
                    class="btn b-s"
                    onclick="filterBatchVouchers('all')"
                    id="bdf-all"
                >
                    Semua
                </button>
                <button
                    class="btn b-s"
                    onclick="filterBatchVouchers('available')"
                    id="bdf-avail"
                >
                    Tersedia
                </button>
                <button
                    class="btn b-s"
                    onclick="filterBatchVouchers('used')"
                    id="bdf-used"
                >
                    Terpakai
                </button>
                <button class="btn b-p" onclick="printCurrentBatch()">
                    <i class="fa fa-print"></i> Print Tersisa
                </button>
                </div>
            </div>
            <div class="card" style="padding: 12px 16px; margin-bottom: 12px">
                <div
                style="
                    display: flex;
                    flex-wrap: wrap;
                    gap: 18px;
                    font-size: 0.83rem;
                "
                >
                <div>
                    <span style="color: var(--muted)">Profile:</span>
                    <b id="bd-profile"></b>
                </div>
                <div>
                    <span style="color: var(--muted)">Harga:</span>
                    <b id="bd-price" style="color: var(--green)"></b>
                </div>
                <div>
                    <span style="color: var(--muted)">Total:</span>
                    <b id="bd-total-price" style="color: var(--acc2)"></b>
                </div>
                <div>
                    <span style="color: var(--muted)">Durasi:</span>
                    <b id="bd-validity"></b>
                </div>
                <div>
                    <span style="color: var(--muted)">Reseller:</span>
                    <b id="bd-reseller"></b>
                </div>
                <div>
                    <span style="color: var(--muted)">Dibuat:</span>
                    <b id="bd-created"></b>
                </div>
                </div>
                <div style="margin-top: 10px">
                <div
                    style="
                    display: flex;
                    justify-content: space-between;
                    font-size: 0.75rem;
                    color: var(--muted);
