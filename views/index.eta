                    <th>Akses Router</th>
                    <th>Status</th>
                    <th>Login Terakhir</th>
                    <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="t-users"></tbody>
                </table>
            </div>
            <div id="pg-t-users"></div>
            </div>
        </div>

        <!-- ══ CHANGE PASSWORD ══ -->
        <div class="page" id="page-change-password">
            <div class="card" style="max-width: 480px">
            <div class="card-hd">
                <i class="fa fa-key"></i> Ganti Password Login
            </div>
            <div class="info-box" style="margin-bottom: 14px">
                <i class="fa fa-info-circle"></i> Ganti password untuk akun
                <b id="cp-username-label">—</b> yang sedang login.
            </div>
            <div class="fg">
                <label>Password Lama</label>
                <input
                type="password"
                id="cp-old"
                class="form-input"
                placeholder="Password saat ini"
                />
            </div>
            <div class="fg">
                <label
                >Password Baru
                <small style="color: var(--muted)"
                    >min. 4 karakter</small
                ></label
                >
                <input
                type="password"
                id="cp-new"
                class="form-input"
                placeholder="Password baru"
                />
            </div>
            <div class="fg">
                <label>Konfirmasi Password Baru</label>
                <input
                type="password"
                id="cp-confirm"
                class="form-input"
                placeholder="Ulangi password baru"
                />
            </div>
            <div class="err" id="cp-err" style="margin-bottom: 10px"></div>
            <button class="btn b-p" onclick="doChangePassword()">
                <i class="fa fa-save"></i> Simpan Password Baru
            </button>
            </div>
        </div>

        <!-- ══ MOBILE API ══ -->
        <div class="page" id="page-mobile-api">
            <div class="card" style="margin-bottom: 14px">
            <div class="card-hd">
                <i class="fa fa-mobile"></i> Mobile API — Dokumentasi & Token
            </div>
            <div class="g2">
                <div>
                <p
                    style="
                    color: var(--muted);
                    font-size: 0.83rem;
                    margin-bottom: 10px;
                    "
                >
                    API ini digunakan untuk aplikasi mobile reseller. Reseller
                    login dengan <b>Telegram ID</b> mereka dan mendapatkan Bearer
                    Token.
                </p>
                <div
                    style="
                    background: var(--card2);
                    border-radius: 8px;
                    padding: 12px;
                    margin-bottom: 10px;
                    "
                >
                    <div
                    style="
                        font-size: 0.75rem;
                        color: var(--muted);
                        margin-bottom: 5px;
                    "
                    >
                    Base URL
                    </div>
                    <code
                    id="api-base-url"
                    style="
                        color: var(--acc2);
                        font-size: 0.85rem;
                        word-break: break-all;
                    "
                    ></code>
                </div>
                <div
                    style="
                    background: var(--card2);
                    border-radius: 8px;
                    padding: 12px;
                    "
                >
                    <div
                    style="
                        font-size: 0.75rem;
                        color: var(--muted);
                        margin-bottom: 5px;
                    "
                    >
                    Cara Autentikasi
                    </div>
                    <code style="font-size: 0.78rem; color: var(--green)"
                    >Authorization: Bearer &lt;token&gt;</code
                    >
                </div>
                </div>
                <div>
                <div
                    style="
                    background: var(--card2);
                    border-radius: 8px;
                    padding: 12px;
                    "
                >
                    <div
                    style="
                        font-weight: 600;
                        font-size: 0.85rem;
                        margin-bottom: 8px;
                    "
                    >
                    <i class="fa fa-key"></i> Test Login API
                    </div>
                    <div class="fg">
                    <label>Telegram ID Reseller</label
                    ><input
                        id="api-test-tid"
                        placeholder="123456789"
                        type="number"
                    />
                    </div>
                    <button
                    class="btn b-p"
                    style="width: 100%; justify-content: center"
                    onclick="testMobileLogin()"
                    >
                    <i class="fa fa-sign-in"></i> Test Login
                    </button>
                    <div
                    id="api-test-result"
                    style="margin-top: 8px; font-size: 0.75rem; display: none"
                    >
                    <div style="color: var(--muted); margin-bottom: 4px">
                        Response:
                    </div>
                    <pre
                        id="api-test-json"
                        style="
                        background: var(--bg);
                        border-radius: 6px;
                        padding: 8px;
                        overflow-x: auto;
                        font-size: 0.73rem;
                        max-height: 150px;
                        overflow-y: auto;
                        "
                    ></pre>
                    </div>
                </div>
                </div>
            </div>
            </div>

            <!-- Endpoint list -->
            <div id="api-endpoint-list"></div>

            <!-- Active tokens -->
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-list"></i> Token Aktif Reseller
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Reseller</th>
                    <th>Telegram ID</th>
                    <th>Session</th>
                    <th>Dibuat</th>
                    <th>Expired</th>
                    <th>Terakhir Dipakai</th>
                    <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="t-api-tokens"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ BILLING ══ -->
        <div class="page" id="page-billing">
            <!-- Stats -->
            <div class="grid g4" style="margin-bottom: 14px" id="bill-stats-grid">
            <div class="sbc c-blue" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-users"></i>
                </div>
                <div>
                <div class="sbc-val" id="bill-total" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Total Pelanggan</div>
                </div>
            </div>
            <div class="sbc c-green" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-check-circle"></i>
                </div>
                <div>
                <div class="sbc-val" id="bill-active" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Aktif</div>
                </div>
            </div>
            <div class="sbc c-red" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-exclamation-circle"></i>
                </div>
                <div>
                <div class="sbc-val" id="bill-unpaid" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Belum Bayar</div>
                </div>
            </div>
            <div class="sbc c-yellow" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-ban"></i>
                </div>
                <div>
                <div
                    class="sbc-val"
                    id="bill-suspended"
                    style="font-size: 1.3rem"
                >
                    0
                </div>
                <div class="sbc-lbl">Diblokir</div>
                </div>
            </div>
            </div>

            <div class="card">
            <div class="card-hd" style="flex-wrap: wrap; gap: 8px">
                <span><i class="fa fa-users"></i> Daftar Pelanggan</span>
                <div class="ml" style="display: flex; gap: 7px; flex-wrap: wrap">
                <select
                    id="bill-type-filter"
                    onchange="loadBilling()"
                    style="max-width: 120px"
                >
                    <option value="">Semua Tipe</option>
                    <option value="pppoe">PPPoE</option>
                    <option value="hotspot">Hotspot</option>
                </select>
                <select
                    id="bill-status-filter"
                    onchange="loadBilling()"
                    style="max-width: 130px"
                >
                    <option value="">Semua Status</option>
                    <option value="active">Aktif</option>
                    <option value="suspended">Diblokir</option>
                </select>
                <button
                    class="btn b-s b-sm"
                    onclick="runOverdue()"
                    title="Cek & blokir yang belum bayar"
                >
                    <i class="fa fa-ban"></i> Proses Overdue
                </button>
                <button class="btn b-p b-sm" onclick="openBillCustomerModal()">
                    <i class="fa fa-plus"></i> Tambah Pelanggan
                </button>
                </div>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Nama</th>
                    <th>Username MikroTik</th>
                    <th>Tipe</th>
                    <th>Paket</th>
                    <th>Tagihan/Bulan</th>
                    <th>Tgl Tagih</th>
                    <th>Status</th>
                    <th>Telegram</th>
                    <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="t-billing"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ INVOICES ══ -->
        <div class="page" id="page-invoices">
            <div class="grid g3" style="margin-bottom: 14px">
            <div class="sbc c-red" style="padding: 12px">
                <div>
                <div
                    class="sbc-val"
                    id="inv-unpaid-ct"
                    style="font-size: 1.3rem"
                >
                    0
                </div>
                <div class="sbc-lbl">Belum Bayar</div>
                </div>
            </div>
            <div class="sbc c-green" style="padding: 12px">
                <div>
                <div class="sbc-val" id="inv-paid-ct" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Lunas Bulan Ini</div>
                </div>
            </div>
            <div class="sbc c-cyan" style="padding: 12px">
                <div>
                <div
                    class="sbc-val"
                    id="inv-income"
                    style="font-size: 0.95rem; padding-top: 5px"
                >
                    Rp 0
                </div>
                <div class="sbc-lbl">Pendapatan Bulan Ini</div>
                </div>
            </div>
            </div>

            <div class="card">
            <div class="card-hd" style="flex-wrap: wrap; gap: 8px">
                <span><i class="fa fa-list-alt"></i> Daftar Tagihan</span>
                <div class="ml" style="display: flex; gap: 7px; flex-wrap: wrap">
                <select
                    id="inv-status-filter"
                    onchange="loadInvoices()"
                    style="max-width: 130px"
                >
                    <option value="">Semua</option>
                    <option value="unpaid">Belum Bayar</option>
                    <option value="paid">Lunas</option>
                    <option value="overdue">Overdue</option>
                </select>
                <button class="btn b-s b-sm" onclick="generateInvoices()">
                    <i class="fa fa-bolt"></i> Generate Tagihan Bulan Ini
                </button>
                </div>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>ID</th>
                    <th>Pelanggan</th>
                    <th>Tipe</th>
                    <th>Periode</th>
                    <th style="text-align: right">Tagihan</th>
                    <th>Jatuh Tempo</th>
                    <th>Status</th>
                    <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="t-invoices"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ BOT RESELLER ══ -->
        <div class="page" id="page-bot-reseller">
            <!-- Stat bar -->
            <div class="grid g4" style="margin-bottom: 14px">
            <div class="sbc c-green" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-users"></i>
                </div>
                <div>
                <div class="sbc-val" id="brs-total" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Total Agen</div>
                </div>
            </div>
            <div class="sbc c-blue" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-check-circle"></i>
                </div>
                <div>
                <div class="sbc-val" id="brs-active" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Aktif</div>
                </div>
            </div>
            <div class="sbc c-yellow" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-ticket"></i>
                </div>
                <div>
                <div class="sbc-val" id="brs-vcr" style="font-size: 1.3rem">
                    0
                </div>
                <div class="sbc-lbl">Total Voucher</div>
                </div>
            </div>
            <div class="sbc c-cyan" style="padding: 12px">
                <div
                class="sbc-icon"
                style="width: 32px; height: 32px; font-size: 0.85rem"
                >
                <i class="fa fa-money"></i>
                </div>
                <div>
                <div
                    class="sbc-val"
                    id="brs-income"
                    style="font-size: 0.95rem; padding-top: 5px"
                >
                    Rp 0
                </div>
                <div class="sbc-lbl">Total Pendapatan</div>
                </div>
            </div>
            </div>

            <div class="card">
            <div class="card-hd">
                <i class="fa fa-users"></i> Daftar Agen Reseller
                <div
                class="ml"
                style="display: flex; gap: 7px; align-items: center"
                >
                <input
                    id="brs-q"
                    placeholder="Cari nama / username / ID..."
                    oninput="filterTbl('t-brs', 'brs-q')"
                    style="max-width: 220px"
                />
                <button class="btn b-p b-sm" onclick="openBrsModal()">
                    <i class="fa fa-plus"></i> Tambah Agen
                </button>
                </div>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Agen</th>
                    <th>Telegram ID</th>
                    <th style="text-align: right">Saldo</th>
                    <th style="text-align: center">Voucher</th>
                    <th style="text-align: right">Pendapatan</th>
                    <th>Status</th>
                    <th>Daftar</th>
                    <th>Aksi</th>
                    </tr>
                </thead>
                <tbody id="t-brs"></tbody>
                </table>
            </div>
            </div>

            <!-- Topup Log -->
            <div class="card" id="brs-log-card" style="display: none">
            <div class="card-hd">
                <i class="fa fa-history"></i> Riwayat Topup —
                <span id="brs-log-name" style="color: var(--acc2)"></span>
                <button
                class="btn b-s b-sm ml"
                onclick="
                    document.getElementById('brs-log-card').style.display = 'none'
                "
                >
                <i class="fa fa-times"></i>
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Waktu</th>
                    <th>Tipe</th>
                    <th style="text-align: right">Jumlah</th>
                    <th style="text-align: right">Saldo Sebelum</th>
                    <th style="text-align: right">Saldo Sesudah</th>
                    <th>Keterangan</th>
                    <th>Oleh</th>
                    </tr>
                </thead>
                <tbody id="t-brs-log"></tbody>
                </table>
            </div>
            </div>
        </div>

        <!-- ══ SESSIONS ══ -->
        <div class="page" id="page-sessions">
            <div class="card">
            <div class="card-hd">
                <i class="fa fa-server"></i> Router Sessions
                <button class="btn b-p b-sm ml" onclick="openSessionModal()">
                <i class="fa fa-plus"></i> Add Router
                </button>
            </div>
            <div style="overflow-x: auto">
                <table>
                <thead>
                    <tr>
                    <th>Name</th>
                    <th>IP</th>
                    <th>Port</th>
                    <th>Currency</th>
                    <th>Live Report</th>
                    <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="t-sess"></tbody>
                </table>
            </div>
            <div id="pg-t-sess"></div>
            </div>
        </div>
    </div>

    <!-- ══ MODALS ══ -->
    <!-- User Modal -->
    <div class="ov" id="m-um">
      <div
        class="modal"
        style="width: 560px; max-height: 92vh; overflow-y: auto"
      >
        <h3>
          <i class="fa fa-user-plus"></i> <span id="mum-ttl">Tambah User</span>
        </h3>

        <div class="fg2">
          <div class="fg">
            <label
              >Username
              <small style="color: var(--muted)">untuk login</small></label
            ><input
              id="mum-un"
              placeholder="user01"
              oninput="
                this.value = this.value.toLowerCase().replace(/[^a-z0-9_]/g, '')
              "
            />
          </div>
          <div class="fg">
            <label>Nama Lengkap</label
            ><input id="mum-nm" placeholder="Nama pengguna" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Password
              <small
                id="mum-pw-hint"
                style="color: var(--muted)"
              ></small></label
            ><input type="password" id="mum-pw" placeholder="min. 4 karakter" />
          </div>
          <div class="fg">
            <label>Role</label>
            <select id="mum-role" onchange="onRoleChange()">
              <option value="admin">Admin — Akses Penuh</option>
              <option value="reseller">Reseller — Voucher & Laporan</option>
              <option value="collector">Collector — Billing & Tagihan</option>
            </select>
          </div>
        </div>
        <div class="fg">
          <label
            >Akses Router
            <small style="color: var(--muted)"
              >kosong = semua router</small
            ></label
          >
          <div
            id="mum-sessions-list"
            style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 5px"
          ></div>
        </div>

        <hr style="border-color: var(--border); margin: 14px 0" />
        <div
          style="
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--muted);
            margin-bottom: 10px;
          "
        >
          <i class="fa fa-shield"></i> Permissions — centang untuk mengizinkan
        </div>
        <div
          id="mum-perms"
          style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px"
        ></div>

        <div class="fg" style="margin-top: 14px">
          <label
            >Catatan
            <small style="color: var(--muted)">(opsional)</small></label
          ><input id="mum-note" placeholder="Catatan tentang user ini" />
        </div>
        <div class="fg">
          <label>Status</label
          ><select id="mum-active">
            <option value="true">Aktif</option>
            <option value="false">Nonaktif</option>
          </select>
        </div>

        <div class="err" id="mum-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-um')">Batal</button
          ><button class="btn b-p" onclick="saveUm()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Reset Password Modal -->
    <div class="ov" id="m-reset-pw">
      <div class="modal" style="width: 400px">
        <h3><i class="fa fa-key"></i> Reset Password</h3>
        <p style="color: var(--muted); font-size: 0.83rem; margin-bottom: 14px">
          Reset password untuk user <b id="rpw-name"></b>. User harus ganti
          password setelah login.
        </p>
        <div class="fg">
          <label>Password Baru</label
          ><input type="password" id="rpw-new" placeholder="min. 4 karakter" />
        </div>
        <div class="fg">
          <label>Konfirmasi</label
          ><input
            type="password"
            id="rpw-confirm"
            placeholder="ulangi password baru"
          />
        </div>
        <div class="err" id="rpw-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-reset-pw')">Batal</button
          ><button class="btn b-p" onclick="doResetPw()">
            <i class="fa fa-check"></i> Reset Password
          </button>
        </div>
      </div>
    </div>

    <!-- Billing Customer Modal -->
    <div class="ov" id="m-bill">
      <div
        class="modal"
        style="width: 560px; max-height: 90vh; overflow-y: auto"
      >
        <h3>
          <i class="fa fa-user-plus"></i>
          <span id="mbill-ttl">Tambah Pelanggan</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>Nama Pelanggan</label
            ><input id="mb-nm" placeholder="Nama lengkap" />
          </div>
          <div class="fg">
            <label>No. HP / WA</label><input id="mb-ph" placeholder="08xxx" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Tipe Layanan</label>
            <select id="mb-tp" onchange="loadBillUsers()">
              <option value="pppoe">PPPoE</option>
              <option value="hotspot">Hotspot Member</option>
            </select>
          </div>
          <div class="fg">
            <label>Username MikroTik</label>
            <select id="mb-user">
              <option value="">Loading...</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Paket / Profile</label
            ><input id="mb-prof" placeholder="PPPoE-10M" readonly />
          </div>
          <div class="fg">
            <label>Harga Tagihan/Bulan (Rp)</label
            ><input id="mb-price" type="number" min="0" placeholder="100000" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Tanggal Tagih
              <small style="color: var(--muted)">(tgl 1-28)</small></label
            ><input id="mb-date" type="number" min="1" max="28" value="1" />
          </div>
          <div class="fg">
            <label>Grace Period (hari)</label
            ><input id="mb-grace" type="number" min="0" max="30" value="3" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Telegram ID Pelanggan
              <small style="color: var(--muted)">(untuk notif)</small></label
            ><input id="mb-tg" placeholder="opsional" />
          </div>
          <div class="fg">
            <label>Status</label>
            <select id="mb-st">
              <option value="active">Aktif</option>
              <option value="suspended">Diblokir</option>
            </select>
          </div>
        </div>
        <div class="fg">
          <label>Pengingat tagihan (hari sebelum jatuh tempo)</label>
          <div
            style="display: flex; gap: 8px; margin-top: 5px; flex-wrap: wrap"
          >
            <label
              style="
                display: flex;
                align-items: center;
                gap: 5px;
                font-size: 0.8rem;
                color: var(--text);
              "
              ><input type="checkbox" id="mb-rem7" checked /> 7 hari</label
            >
            <label
              style="
                display: flex;
                align-items: center;
                gap: 5px;
                font-size: 0.8rem;
                color: var(--text);
              "
              ><input type="checkbox" id="mb-rem3" checked /> 3 hari</label
            >
            <label
              style="
                display: flex;
                align-items: center;
                gap: 5px;
                font-size: 0.8rem;
                color: var(--text);
              "
              ><input type="checkbox" id="mb-rem1" checked /> 1 hari</label
            >
            <label
              style="
                display: flex;
                align-items: center;
                gap: 5px;
                font-size: 0.8rem;
                color: var(--text);
              "
              ><input type="checkbox" id="mb-rem0" /> H-0 (hari H)</label
            >
          </div>
        </div>
        <div class="fg">
          <label>Auto-disable jika belum bayar</label>
          <select id="mb-auto">
            <option value="true">Ya (otomatis blokir)</option>
            <option value="false">Tidak (manual)</option>
          </select>
        </div>
        <div class="fg">
          <label>Catatan</label><input id="mb-note" placeholder="opsional" />
        </div>
        <div class="err" id="mb-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-bill')">Batal</button
          ><button class="btn b-p" onclick="saveBillCustomer()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Pay Invoice Modal -->
    <div class="ov" id="m-pay">
      <div class="modal" style="width: 420px">
        <h3><i class="fa fa-check-circle"></i> Konfirmasi Pembayaran</h3>
        <div
          style="
            background: var(--card2);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 14px;
          "
        >
          <div style="font-weight: 600" id="pay-name">—</div>
          <div style="color: var(--muted); font-size: 0.8rem" id="pay-period">
            —
          </div>
          <div style="margin-top: 6px; font-size: 0.95rem">
            Tagihan: <b style="color: var(--green)" id="pay-amount">Rp 0</b>
          </div>
          <div style="font-size: 0.78rem; color: var(--muted); margin-top: 2px">
            Jatuh tempo: <span id="pay-due">—</span>
          </div>
        </div>
        <div class="fg">
          <label>Diterima Oleh</label><input id="pay-by" placeholder="Admin" />
        </div>
        <div class="fg">
          <label>Keterangan</label
          ><input id="pay-note" placeholder="Transfer, Cash, dst..." />
        </div>
        <div class="err" id="pay-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-pay')">Batal</button>
          <button
            class="btn b-p"
            onclick="confirmPay()"
            style="background: var(--green)"
          >
            <i class="fa fa-check"></i> Lunas
          </button>
        </div>
      </div>
    </div>

    <!-- Send Reminder Modal -->
    <div class="ov" id="m-reminder">
      <div class="modal" style="width: 420px">
        <h3><i class="fa fa-paper-plane"></i> Kirim Reminder Telegram</h3>
        <p style="color: var(--muted); font-size: 0.82rem; margin-bottom: 12px">
          Preview pesan yang akan dikirim:
        </p>
        <div
          id="rem-preview"
          style="
            background: var(--card2);
            border-radius: 8px;
            padding: 12px;
            font-size: 0.8rem;
            white-space: pre-wrap;
            max-height: 200px;
            overflow-y: auto;
            line-height: 1.6;
          "
        ></div>
        <div class="err" id="rem-err" style="margin-top: 8px"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-reminder')">Batal</button>
          <button class="btn b-p" onclick="sendReminder()">
            <i class="fa fa-paper-plane"></i> Kirim Sekarang
          </button>
        </div>
      </div>
    </div>

    <!-- Bot Reseller Modal -->
    <div class="ov" id="m-brs">
      <div class="modal" style="width: 500px">
        <h3>
          <i class="fa fa-users"></i> <span id="mbrs-ttl">Tambah Agen</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>Nama Agen</label
            ><input id="mbrs-nm" placeholder="Nama lengkap" />
          </div>
          <div class="fg">
            <label
              >Username Telegram
              <small style="color: var(--muted)">@user</small></label
            ><input id="mbrs-un" placeholder="@username" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Telegram ID
              <small style="color: var(--muted)">angka numeric</small></label
            ><input id="mbrs-tid" placeholder="1234567890" type="number" />
          </div>
          <div class="fg">
            <label>Status</label
            ><select id="mbrs-st">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Diskon %
              <small style="color: var(--muted)"
                >dari selling price</small
              ></label
            ><input id="mbrs-dc" type="number" value="0" min="0" max="100" />
          </div>
          <div class="fg">
            <label>Saldo Awal (Rp)</label
            ><input id="mbrs-sl" type="number" value="0" min="0" />
          </div>
        </div>
        <div class="fg">
          <label>Catatan</label><input id="mbrs-nt" placeholder="opsional" />
        </div>
        <div class="err" id="mbrs-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-brs')">Batal</button
          ><button class="btn b-p" onclick="saveBrs()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Topup Saldo Modal -->
    <div class="ov" id="m-topup">
      <div class="modal" style="width: 420px">
        <h3><i class="fa fa-money"></i> Topup Saldo</h3>
        <div
          style="
            background: var(--card2);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 14px;
          "
        >
          <div style="font-weight: 600; font-size: 0.92rem" id="tp-name">—</div>
          <div style="color: var(--muted); font-size: 0.8rem" id="tp-tid">
            —
          </div>
          <div style="margin-top: 6px; font-size: 0.85rem">
            Saldo saat ini: <b style="color: var(--green)" id="tp-cur">Rp 0</b>
          </div>
        </div>
        <div class="fg">
          <label
            >Jumlah Topup (Rp)
            <small style="color: var(--muted)"
              >negatif = potong saldo</small
            ></label
          ><input
            id="tp-amt"
            type="number"
            min="-9999999"
            placeholder="50000"
          />
        </div>
        <div
          style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px"
        >
          <button class="btn b-s b-sm" onclick="quickTopup(10000)">+10K</button>
          <button class="btn b-s b-sm" onclick="quickTopup(20000)">+20K</button>
          <button class="btn b-s b-sm" onclick="quickTopup(50000)">+50K</button>
          <button class="btn b-s b-sm" onclick="quickTopup(100000)">
            +100K
          </button>
          <button class="btn b-s b-sm" onclick="quickTopup(200000)">
            +200K
          </button>
          <button class="btn b-s b-sm" onclick="quickTopup(500000)">
            +500K
          </button>
        </div>
        <div class="fg">
          <label>Keterangan</label
          ><input id="tp-note" placeholder="Transfer BRI, dst..." />
        </div>
        <div class="err" id="tp-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-topup')">Batal</button>
          <button class="btn b-p" onclick="doTopup()">
            <i class="fa fa-check"></i> Proses Topup
          </button>
        </div>
      </div>
    </div>

    <!-- Reseller Bot Modal -->
    <div class="ov" id="m-rb">
      <div class="modal" style="width: 500px">
        <h3>
          <i class="fa fa-users"></i> <span id="mrb-ttl">Tambah Reseller</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>Nama Lengkap</label
            ><input id="mrb-name" placeholder="Nama reseller" />
          </div>
          <div class="fg">
            <label
              >Username Telegram
              <small style="color: var(--muted)">tanpa @</small></label
            ><input id="mrb-uname" placeholder="username123" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Telegram ID
              <small style="color: var(--muted)">angka</small></label
            ><input id="mrb-tid" placeholder="123456789" type="number" />
          </div>
          <div class="fg">
            <label>Router Session</label
            ><select id="mrb-sess">
              <option value="">Pilih router...</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Markup per Voucher (Rp)</label
            ><input id="mrb-markup" type="number" value="0" min="0" />
          </div>
          <div class="fg">
            <label>Status</label
            ><select id="mrb-status">
              <option value="active">Aktif</option>
              <option value="inactive">Nonaktif</option>
            </select>
          </div>
        </div>
        <div class="err" id="mrb-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-rb')">Batal</button
          ><button class="btn b-p" onclick="saveRb()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Topup Modal -->
    <div class="ov" id="m-topup">
      <div class="modal" style="width: 420px">
        <h3><i class="fa fa-money"></i> Topup Saldo Reseller</h3>
        <input type="hidden" id="tu-id" />
        <div
          style="
            background: var(--card2);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 14px;
          "
        >
          <div style="font-size: 0.82rem; color: var(--muted)">Reseller</div>
          <div id="tu-name" style="font-weight: 700; font-size: 0.95rem"></div>
          <div style="font-size: 0.82rem; color: var(--muted); margin-top: 4px">
            Saldo saat ini:
            <b id="tu-current-saldo" style="color: var(--green)"></b>
          </div>
        </div>
        <div class="fg">
          <label>Jumlah Topup (Rp)</label
          ><input
            id="tu-amount"
            type="number"
            min="1000"
            step="1000"
            placeholder="50000"
          />
        </div>
        <div class="fg">
          <label>Catatan</label
          ><input id="tu-note" placeholder="Transfer BRI / Tunai / dll..." />
        </div>
        <div
          id="tu-preview"
          style="
            background: var(--acc) 15;
            border: 1px solid var(--acc) 30;
            border-radius: 7px;
            padding: 9px;
            font-size: 0.82rem;
            margin-top: 4px;
            display: none;
          "
        >
          Saldo setelah topup: <b id="tu-after" style="color: var(--green)"></b>
        </div>
        <div class="err" id="tu-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-topup')">Batal</button
          ><button class="btn b-p" onclick="doTopup()">
            <i class="fa fa-money"></i> Topup Sekarang
          </button>
        </div>
      </div>
    </div>

    <!-- Import Voucher Modal -->
    <div class="ov" id="m-import">
      <div class="modal" style="width: 560px">
        <h3><i class="fa fa-download"></i> Import Voucher dari MikroTik</h3>
        <p style="color: var(--muted); font-size: 0.82rem; margin-bottom: 14px">
          Pilih profile yang ingin diimport. Import dilakukan satu per satu agar
          tidak timeout.
        </p>

        <!-- Step 1: Profile list -->
        <div id="imp-step1">
          <div
            id="imp-profiles-list"
            style="max-height: 340px; overflow-y: auto"
          >
            <div style="text-align: center; padding: 20px; color: var(--muted)">
              <i class="fa fa-spinner fa-spin"></i> Memuat daftar profile...
            </div>
          </div>
          <div
            style="
              margin-top: 12px;
              display: flex;
              gap: 7px;
              align-items: center;
              flex-wrap: wrap;
            "
          >
            <label style="font-size: 0.78rem; color: var(--muted)"
              >Cek selling script:</label
            >
            <select id="imp-months" style="max-width: 160px; width: auto">
              <option value="1">1 bulan terakhir</option>
              <option value="3" selected>3 bulan terakhir</option>
              <option value="6">6 bulan terakhir</option>
              <option value="12">12 bulan terakhir</option>
            </select>
          </div>
          <div
            style="
              margin-top: 10px;
              display: flex;
              justify-content: space-between;
              align-items: center;
            "
          >
            <button class="btn b-s b-sm" onclick="selectAllProfiles()">
              <i class="fa fa-check-square-o"></i> Pilih Semua
            </button>
            <div style="display: flex; gap: 7px">
              <button class="btn b-s" onclick="closeM('m-import')">
                Batal
              </button>
              <button
                class="btn b-p"
                id="imp-start-btn"
                onclick="startImport()"
              >
                <i class="fa fa-play"></i> Mulai Import
              </button>
            </div>
          </div>
        </div>

        <!-- Step 2: Progress -->
        <div id="imp-step2" style="display: none">
          <div
            id="imp-progress-list"
            style="max-height: 340px; overflow-y: auto"
          ></div>
          <div style="margin-top: 12px">
            <div
              style="
                display: flex;
                justify-content: space-between;
                font-size: 0.78rem;
                color: var(--muted);
                margin-bottom: 5px;
              "
            >
              <span id="imp-progress-label">0 / 0 selesai</span>
              <span id="imp-progress-pct">0%</span>
            </div>
            <div
              style="
                background: var(--border);
                border-radius: 4px;
                height: 7px;
                overflow: hidden;
              "
            >
              <div
                id="imp-progress-bar"
                style="
                  height: 100%;
                  background: var(--acc2);
                  border-radius: 4px;
                  transition: 0.3s;
                  width: 0%;
                "
              ></div>
            </div>
          </div>
          <div
            style="
              margin-top: 12px;
              display: flex;
              justify-content: flex-end;
              gap: 7px;
            "
          >
            <div
              id="imp-summary"
              style="flex: 1; font-size: 0.8rem; color: var(--muted)"
            ></div>
            <button
              class="btn b-p"
              id="imp-done-btn"
              onclick="
                closeM('m-import');
                loadBatchList();
              "
              style="display: none"
            >
              <i class="fa fa-check"></i> Selesai — Lihat Batch
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Print Voucher Modal -->
    <div class="ov" id="m-print" style="z-index: 2000">
      <div
        class="modal"
        style="
          width: 98vw;
          max-width: 1100px;
          max-height: 95vh;
          padding: 0;
          overflow: hidden;
          display: flex;
          flex-direction: column;
        "
      >
        <!-- Header -->
        <div
          style="
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
          "
        >
          <div style="flex: 1">
            <h3 style="margin: 0; font-size: 0.95rem">
              <i class="fa fa-print"></i> Print Voucher (<span id="pv-count"
                >0</span
              >
              buah)
            </h3>
          </div>
          <button class="btn b-p" onclick="downloadPDF()" style="gap: 6px">
            <i class="fa fa-download"></i> Download PDF
          </button>
          <button
            class="btn b-p"
            onclick="doPrint()"
            style="background: var(--green); gap: 6px"
          >
            <i class="fa fa-print"></i> Print
          </button>
          <button class="btn b-s" onclick="closeM('m-print')">Tutup</button>
        </div>
        <!-- Controls -->
        <div
          style="
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 20px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            flex-wrap: wrap;
            font-size: 0.82rem;
            color: var(--muted);
          "
        >
          <span>Kertas:</span>
          <div style="display: flex; gap: 4px" id="paper-btns">
            <button class="pv-btn active" onclick="setPaper('A4', this)">
              A4
            </button>
            <button class="pv-btn" onclick="setPaper('F4', this)">F4</button>
          </div>
          <span style="margin-left: 8px">Orientasi:</span>
          <div style="display: flex; gap: 4px" id="orient-btns">
            <button class="pv-btn active" onclick="setOrient('portrait', this)">
              Portrait
            </button>
            <button class="pv-btn" onclick="setOrient('landscape', this)">
              Landscape
            </button>
          </div>
          <span style="margin-left: 8px">Kolom:</span>
          <div style="display: flex; gap: 4px" id="col-btns">
            <button class="pv-btn" onclick="setCols(3, this)">3</button>
            <button class="pv-btn" onclick="setCols(4, this)">4</button>
            <button class="pv-btn active" onclick="setCols(5, this)">5</button>
            <button class="pv-btn" onclick="setCols(6, this)">6</button>
            <button class="pv-btn" onclick="setCols(7, this)">7</button>
          </div>
          <span
            id="pv-info"
            style="margin-left: auto; color: var(--acc2); font-weight: 500"
          ></span>
        </div>
        <!-- Preview -->
        <div
          style="
            flex: 1;
            overflow-y: auto;
            padding: 14px;
            background: var(--bg);
          "
        >
          <div id="pv-preview"></div>
        </div>
      </div>
    </div>

    <!-- Session Modal -->
    <div class="ov" id="m-sess">
      <div class="modal">
        <h3>
          <i class="fa fa-server"></i> <span id="ms-ttl">Add Router</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>Session ID</label
            ><input
              id="ms-id"
              placeholder="SIWARNET"
              oninput="
                this.value = this.value.toUpperCase().replace(/[^A-Z0-9_]/g, '')
              "
            />
          </div>
          <div class="fg">
            <label>Display Name</label
            ><input id="ms-nm" placeholder="My Router" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>IP Address</label
            ><input id="ms-ip" placeholder="192.168.1.1" />
          </div>
          <div class="fg">
            <label>API Port</label
            ><input id="ms-pt" type="number" value="8728" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>API Username</label><input id="ms-us" placeholder="admin" />
          </div>
          <div class="fg">
            <label
              >API Password
              <small id="ms-ph" style="color: var(--muted)"></small></label
            ><input id="ms-pw" type="password" placeholder="password" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Currency</label><input id="ms-cr" value="Rp" />
          </div>
          <div class="fg">
            <label>Live Report</label
            ><select id="ms-lv">
              <option value="enable">Enable</option>
              <option value="disable">Disable</option>
            </select>
          </div>
        </div>
        <div class="err" id="ms-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-sess')">Batal</button
          ><button class="btn b-p" onclick="saveSession()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- HS Profile Modal -->
    <div class="ov" id="m-hsp">
      <div class="modal">
        <h3>
          <i class="fa fa-id-card"></i> <span id="mhp-ttl">Add HS Profile</span>
        </h3>
        <div class="fg">
          <label>Profile Name</label
          ><input id="mhp-nm" placeholder="VOCER-1K" />
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Rate Limit</label><input id="mhp-rl" placeholder="2M/2M" />
          </div>
          <div class="fg">
            <label>Shared Users</label
            ><input id="mhp-su" type="number" value="1" min="1" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Session Timeout</label
            ><input id="mhp-st" placeholder="00:00:00" />
          </div>
          <div class="fg">
            <label>Idle Timeout</label
            ><input id="mhp-it" placeholder="00:05:00" />
          </div>
        </div>
        <div class="fg">
          <label>Address Pool</label><input id="mhp-ap" placeholder="hs-pool" />
        </div>
        <hr style="border-color: var(--border); margin: 12px 0" />
        <div class="fg">
          <label>Expired Mode</label
          ><select id="mhp-em">
            <option value="">None</option>
            <option value="rem">Remove</option>
            <option value="ntf">Notice</option>
            <option value="remc">Remove &amp; Record</option>
            <option value="ntfc">Notice &amp; Record</option>
          </select>
        </div>
        <div class="fg">
          <label
            >Validity
            <small style="color: var(--muted)">e.g. 4h, 1d, 7d</small></label
          ><input id="mhp-vl" placeholder="1d" />
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Price (Modal) Rp</label
            ><input id="mhp-pr" type="number" value="0" />
          </div>
          <div class="fg">
            <label>Selling Price Rp</label
            ><input id="mhp-sp" type="number" value="0" />
          </div>
        </div>
        <div class="fg">
          <label>Lock User</label
          ><select id="mhp-lu">
            <option value="">Disable</option>
            <option value="Enable">Enable</option>
          </select>
        </div>
        <div class="fg2">
          <div class="fg">
            <label
              >Warna Voucher
              <small style="color: var(--muted)">(untuk print)</small></label
            >
            <div style="display: flex; gap: 8px; align-items: center">
              <input
                type="color"
                id="mhp-color"
                value="#1f6feb"
                style="
                  width: 44px;
                  height: 34px;
                  padding: 2px;
                  cursor: pointer;
                  flex-shrink: 0;
                "
              />
              <input
                id="mhp-color-hex"
                placeholder="#1f6feb"
                style="font-family: monospace"
                oninput="syncColorHex()"
                maxlength="7"
              />
            </div>
          </div>
          <div class="fg">
            <label>Caption Voucher</label
            ><input id="mhp-caption" placeholder="cth: Hotspot 10M" />
          </div>
        </div>
        <div class="err" id="mhp-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-hsp')">Batal</button
          ><button class="btn b-p" onclick="saveHsProfile()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- PPPoE User Modal -->
    <div class="ov" id="m-pu">
      <div class="modal">
        <h3>
          <i class="fa fa-users"></i> <span id="mpu-ttl">Add PPPoE User</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>Username</label><input id="mpu-nm" placeholder="user01" />
          </div>
          <div class="fg">
            <label>Password</label
            ><input id="mpu-pw" type="password" placeholder="password" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Profile</label
            ><select id="mpu-pr">
              <option value="default">default</option>
            </select>
          </div>
          <div class="fg">
            <label>Service</label
            ><select id="mpu-sv">
              <option value="pppoe">pppoe</option>
              <option value="any">any</option>
              <option value="pptp">pptp</option>
              <option value="l2tp">l2tp</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Local Address</label
            ><input id="mpu-la" placeholder="opsional" />
          </div>
          <div class="fg">
            <label>Remote Address</label
            ><input id="mpu-ra" placeholder="opsional" />
          </div>
        </div>
        <div class="fg">
          <label>Comment</label
          ><input id="mpu-cm" placeholder="Nama pelanggan" />
        </div>
        <div class="err" id="mpu-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-pu')">Batal</button
          ><button class="btn b-p" onclick="savePppUser()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- PPPoE Profile Modal -->
    <div class="ov" id="m-pp">
      <div class="modal">
        <h3>
          <i class="fa fa-id-card-o"></i>
          <span id="mpp-ttl">Add PPPoE Profile</span>
        </h3>
        <div class="fg">
          <label>Profile Name</label
          ><input id="mpp-nm" placeholder="PPPoE-10M" />
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Rate Limit</label><input id="mpp-rl" placeholder="10M/10M" />
          </div>
          <div class="fg">
            <label>Address Pool</label
            ><input id="mpp-ap" placeholder="pppoe-pool" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Local Address</label
            ><input id="mpp-la" placeholder="opsional" />
          </div>
          <div class="fg">
            <label>Session Timeout</label
            ><input id="mpp-st" placeholder="00:00:00" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Idle Timeout</label
            ><input id="mpp-it" placeholder="00:05:00" />
          </div>
          <div class="fg">
            <label>Only One</label
            ><select id="mpp-oo">
              <option value="default">default</option>
              <option value="yes">yes</option>
              <option value="no">no</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Comment</label><input id="mpp-cm" placeholder="" />
          </div>
          <div class="fg" style="max-width: 120px">
            <label>Status</label
            ><select id="mpp-act">
              <option value="true">Aktif</option>
              <option value="false">Nonaktif</option>
            </select>
          </div>
        </div>
        <div class="err" id="mpp-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-pp')">Batal</button
          ><button class="btn b-p" onclick="savePppProfile()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Reseller Modal -->
    <div class="ov" id="m-rs">
      <div class="modal">
        <h3>
          <i class="fa fa-handshake-o"></i>
          <span id="mrs-ttl">Add Reseller</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label>ID/Tag</label
            ><input
              id="mrs-id"
              placeholder="MOM"
              oninput="
                this.value = this.value.toUpperCase().replace(/[^A-Z0-9_]/g, '')
              "
            />
          </div>
          <div class="fg">
            <label>Nama</label><input id="mrs-nm" placeholder="Nama reseller" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>No. HP</label><input id="mrs-ph" placeholder="08xxx" />
          </div>
          <div class="fg">
            <label>Diskon %</label
            ><input id="mrs-dc" type="number" value="0" min="0" max="100" />
          </div>
        </div>
        <div class="fg">
          <label>Alamat</label><textarea id="mrs-ad" rows="2"></textarea>
        </div>
        <div class="err" id="mrs-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-rs')">Batal</button
          ><button class="btn b-p" onclick="saveReseller()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>

    <!-- Voucher Type Modal -->
    <div class="ov" id="m-vt">
      <div class="modal" style="width: 520px">
        <h3>
          <i class="fa fa-cog"></i>
          <span id="mvt-ttl">Tambah Tipe Voucher</span>
        </h3>
        <div class="fg2">
          <div class="fg">
            <label
              >Nama
              <small style="color: var(--muted)">e.g. VOCER 1K</small></label
            ><input id="mvt-nm" placeholder="VOCER 1K" />
          </div>
          <div class="fg">
            <label>Harga Jual (Rp)</label
            ><input id="mvt-pr" type="number" value="1000" min="0" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Profile MikroTik</label
            ><select id="mvt-prof">
              <option value="">Loading...</option>
            </select>
          </div>
          <div class="fg">
            <label
              >Durasi
              <small style="color: var(--muted)">e.g. 4j, 1 hari</small></label
            ><input id="mvt-dur" placeholder="4j" />
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>User Type</label
            ><select id="mvt-type">
              <option value="up">User + Password</option>
              <option value="vc">User = Password</option>
            </select>
          </div>
          <div class="fg">
            <label>Panjang Kode</label
            ><input id="mvt-len" type="number" value="6" min="4" max="12" />
          </div>
          <div class="fg">
            <label>Format Kode</label
            ><select id="mvt-fmt">
              <option value="upper+digit">Huruf Kapital + Angka</option>
              <option value="lower+digit">Huruf Kecil + Angka</option>
              <option value="mixed+digit">Huruf Besar+Kecil + Angka</option>
              <option value="digit">Angka saja</option>
            </select>
          </div>
        </div>
        <div class="fg2">
          <div class="fg">
            <label>Maks/Order</label
            ><input id="mvt-max" type="number" value="10" min="1" max="200" />
          </div>
          <div class="fg">
            <label>Status</label
            ><select id="mvt-act">
              <option value="true">Aktif</option>
              <option value="false">Nonaktif</option>
            </select>
          </div>
        </div>
        <div class="err" id="mvt-err"></div>
        <div class="mfoot">
          <button class="btn b-s" onclick="closeM('m-vt')">Batal</button
          ><button class="btn b-p" onclick="saveVt()">
            <i class="fa fa-save"></i> Simpan
          </button>
        </div>
      </div>
    </div>
</div>
